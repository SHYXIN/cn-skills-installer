{
  "name": "cn-skills-installer",
  "version": "0.1.0",
  "description": "中国优化的 AI Agent Skills 安装工具 - 支持 Gitee/GitHub 双源、镜像加速、中文索引",
  "type": "module",
  "bin": {
    "cn-skills": "./dist/cli",
    "cn-skills-installer": "./dist/cli"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "index"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean --shims && node -e \"const fs=require('fs'); fs.renameSync('dist/cli.js','dist/cli')\"",
    "dev": "tsx src/cli.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "picocolors": "^1.1.1",
    "simple-git": "^3.27.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "ai-agent",
    "skills",
    "claude-code",
    "cursor",
    "gitee",
    "cn"
  ],
  "license": "MIT"
}
